# YT Studio v1.0 — environment variables
# NOTE: Most secrets can be set from the UI Config tab.
# /app/data/config.json overrides these defaults at startup.

# --- App ---
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-random-32-chars

# --- Storage ---
OUTPUT_DIR=/app/data/output
TEMP_DIR=/tmp/waz
COOKIES_FILE=/app/data/cookies/cookies.txt
CONFIG_FILE=/app/data/config.json

# --- Video output (clipper) ---
VIDEO_WIDTH=720
VIDEO_HEIGHT=1280
FFMPEG_PRESET=ultrafast
FFMPEG_CRF=24
FFMPEG_THREADS=0

# --- yt-dlp / bot bypass (can also be set via Config tab) ---
# POT_PROVIDER_URL removed in YT Studio v1.0 — no longer needed.
YTDLP_PROXY=
VMESS_LINK=

# --- Google Drive OAuth (can also be set via Config tab) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Xray (auto-managed when VMESS_LINK is set) ---
XRAY_BIN=/usr/local/bin/xray
XRAY_CONFIG=/app/data/xray-config.json
XRAY_SOCKS_PORT=10808
